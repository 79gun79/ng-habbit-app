{
  "expo": {
    "name": "NG 습관 앱",
    "slug": "ng-habit-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/favicon/web-app-manifest-512x512.png",
    "scheme": "ng-habit-app",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.anonymous.xnative",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#FFFFFF",
        "foregroundImage": "./assets/images/favicon/web-app-manifest-512x512.png",
        "monochromeImage": "./assets/images/favicon/favicon-96x96.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.anonymous.xnative"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon/favicon-96x96.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/favicon/web-app-manifest-512x512.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#ffffff"
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "231fd8d2-6c5f-48bd-87d9-a48663893a04"
      }
    }
  }
}
